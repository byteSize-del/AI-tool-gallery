# ----------------------------------------------------------------------
# Playground provider keys (set these in Vercel → Project → Settings →
# Environment Variables). Add as many or as few as you like — the
# Playground only shows providers that have a key.
#
# IMPORTANT: these are SERVER-SIDE only. Do NOT prefix them with VITE_,
# or they would be bundled into the browser and exposed publicly.
# ----------------------------------------------------------------------

GROQ_API_KEY=
NVIDIA_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# Optional: if set, the Playground requires this code before it will
# call any model. Leave empty for open access (e.g. during a seminar).
PLAYGROUND_ACCESS_CODE=
